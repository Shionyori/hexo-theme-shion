<article class="post">

  <div class="post-content">
    <%- partial('_partial/outdate-warning', { post: page }) %>
    <%- page.content %>
  </div>

  <% if (theme.post.copyright) { %>
  <div class="post-copyright">
    <p><strong><%= config.author || config.title %></strong></p>
    <p><%= url_for(page.path) %></p>
    <p><%= __('copyright', date(page.date, 'YYYY'), config.author) %></p>
  </div>
  <% } %>

  <footer class="post-footer">
    <%- partial('_partial/share', { page: page }) %>

    <% if (page.tags && page.tags.length) { %>
    <div class="post-tags-footer">
      <% page.tags.forEach(function(tag) { %>
        <a class="tag-link" href="<%= url_for(tag.path) %>"><%= tag.name %></a>
      <% }) %>
    </div>
    <% } %>
  </footer>
</article>

<%
  var prevCover = null;
  if (page.prev) {
    if (page.prev.cover) {
      prevCover = (page.prev.cover.startsWith('/') || page.prev.cover.startsWith('http')) ? url_for(page.prev.cover) : url_for(page.prev.path + page.prev.cover);
    } else if (theme.post.cover && theme.post.cover.default) {
      prevCover = url_for(theme.post.cover.default);
    }
  }
  var nextCover = null;
  if (page.next) {
    if (page.next.cover) {
      nextCover = (page.next.cover.startsWith('/') || page.next.cover.startsWith('http')) ? url_for(page.next.cover) : url_for(page.next.path + page.next.cover);
    } else if (theme.post.cover && theme.post.cover.default) {
      nextCover = url_for(theme.post.cover.default);
    }
  }
%>
<% if (page.prev || page.next) { %>
<nav class="post-nav">
  <% if (page.prev) { %>
    <a class="post-nav-item post-nav-prev<%= prevCover ? ' has-cover' : '' %>" href="<%= url_for(page.prev.path) %>"<%- prevCover ? ' style=\'background-image: url(' + prevCover + ')\'' : '' %>>
      <span class="nav-label"><%= __('prev') %></span>
      <span class="nav-title"><%= page.prev.title %></span>
    </a>
  <% } else { %>
    <span class="post-nav-item post-nav-placeholder"></span>
  <% } %>
  <% if (page.next) { %>
    <a class="post-nav-item post-nav-next<%= nextCover ? ' has-cover' : '' %>" href="<%= url_for(page.next.path) %>"<%- nextCover ? ' style=\'background-image: url(' + nextCover + ')\'' : '' %>>
      <span class="nav-label"><%= __('next') %></span>
      <span class="nav-title"><%= page.next.title %></span>
    </a>
  <% } else { %>
    <span class="post-nav-item post-nav-placeholder"></span>
  <% } %>
</nav>
<% } %>

<%- partial('_partial/comments') %>
