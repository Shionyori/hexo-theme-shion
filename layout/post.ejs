<article class="post">

  <div class="post-content">
    <%- partial('_partial/outdate-warning', { post: page }) %>
    <%- page.content %>
  </div>

  <% if (theme.post.copyright) { %>
  <div class="post-copyright">
    <p><strong><%= config.author || config.title %></strong></p>
    <p><%= url_for(page.path) %></p>
    <p><%= __('copyright', date(page.date, 'YYYY'), config.author) %></p>
  </div>
  <% } %>

  <footer class="post-footer">
    <%- partial('_partial/share', { page: page }) %>

    <% if (page.tags && page.tags.length) { %>
    <div class="post-tags-footer">
      <% page.tags.forEach(function(tag) { %>
        <a class="tag-link" href="<%= url_for(tag.path) %>"><%= tag.name %></a>
      <% }) %>
    </div>
    <% } %>

    <nav class="post-nav">
      <% if (page.prev) { %>
        <a class="post-nav-prev" href="<%= url_for(page.prev.path) %>">
          <span class="nav-label"><%= __('prev') %></span>
          <span class="nav-title"><%= page.prev.title %></span>
        </a>
      <% } %>
      <% if (page.next) { %>
        <a class="post-nav-next" href="<%= url_for(page.next.path) %>">
          <span class="nav-label"><%= __('next') %></span>
          <span class="nav-title"><%= page.next.title %></span>
        </a>
      <% } %>
    </nav>
  </footer>
</article>

<%- partial('_partial/comments') %>
