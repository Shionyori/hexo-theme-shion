<div class="category-page content-card">
  <h1 class="category-title"><%= page.category %></h1>
  <span class="category-count"><%= page.posts.length %> <%= __('posts') %></span>

  <section class="post-list">
    <% page.posts.forEach(function(post, i) { %>
      <%- partial('_partial/post-card', { post: post, index: i }) %>
    <% }) %>
  </section>
</div>

<%- partial('_partial/pagination') %>
