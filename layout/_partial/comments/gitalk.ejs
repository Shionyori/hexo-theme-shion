<div id="gitalk-container"></div>
<script>
  (function() {
    var container = document.getElementById('gitalk-container');
    if (!container) return;

    var observer = new IntersectionObserver(function(entries) {
      if (!entries[0].isIntersecting) return;
      observer.disconnect();

      container.innerHTML = '<div id="gitalk"></div>';
      var css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = 'https://unpkg.com/gitalk@1/dist/gitalk.css';
      document.head.appendChild(css);

      var script = document.createElement('script');
      script.src = 'https://unpkg.com/gitalk@1/dist/gitalk.min.js';
      script.async = true;
      script.onload = function() {
        var gitalk = new Gitalk({
          clientID: '<%= theme.comments.gitalk.clientID %>',
          clientSecret: '<%= theme.comments.gitalk.clientSecret %>',
          repo: '<%= theme.comments.gitalk.repo %>',
          owner: '<%= theme.comments.gitalk.owner %>',
          admin: <%- JSON.stringify(theme.comments.gitalk.admin || []) %>,
          id: decodeURI(location.pathname),
          distractionFreeMode: false,
        });
        gitalk.render('gitalk');
      };
      document.body.appendChild(script);
    }, { threshold: 0.1 });

    observer.observe(container);
  })();
</script>
