<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title><%= page.title ? page.title + ' - ' + config.title : config.title %></title>

<% if (page.excerpt) { %>
<meta name="description" content="<%= strip_html(page.excerpt).trim().substring(0, 160) %>">
<% } else if (config.description) { %>
<meta name="description" content="<%= config.description %>">
<% } %>

<meta property="og:title" content="<%= page.title || config.title %>">
<meta property="og:type" content="<%= page.layout === 'post' ? 'article' : 'website' %>">
<meta property="og:url" content="<%= config.url + page.path %>">
<meta property="og:site_name" content="<%= config.title %>">
<% if (page.excerpt) { %>
<meta property="og:description" content="<%= strip_html(page.excerpt).trim().substring(0, 200) %>">
<% } %>
<% if (page.og_image) { %>
<meta property="og:image" content="<%= page.og_image %>">
<% } %>

<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= page.title || config.title %>">
<% if (page.excerpt) { %>
<meta name="twitter:description" content="<%= strip_html(page.excerpt).trim().substring(0, 200) %>">
<% } %>

<link rel="canonical" href="<%= config.url + page.path %>">
<% if (config.feed && config.feed.atom) { %>
<link rel="alternate" href="<%= config.feed.atom %>" type="application/atom+xml" title="<%= config.title %>">
<% } %>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "<%= page.layout === 'post' ? 'Article' : 'WebSite' %>",
  "name": "<%= page.title || config.title %>",
  "url": "<%= config.url + page.path %>"<% if (page.layout === 'post') { %>,
  "datePublished": "<%= date(page.date, 'YYYY-MM-DDTHH:mm:ssZ') %>",
  "author": { "@type": "Person", "name": "<%= config.author || '' %>" }
  <% } %>
}
</script>

<meta name="theme-color" content="#5B6ABF">
<link rel="icon" href="<%= theme.favicon || '/images/shion/favicon.ico' %>">

<link rel="preconnect" href="https://cdn.jsdelivr.net">

<link rel="stylesheet" href="<%= url_for('/css/main.css') %>">

<%- partial('_partial/analytics') %>
<%- partial('_partial/math') %>

<script>
  (function() {
    var mode = '<%= theme.appearance.default_mode %>';
    var saved = localStorage.getItem('shion-theme');
    if (saved) { mode = saved; }
    else if (mode === 'auto') {
      mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    if (mode === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>
