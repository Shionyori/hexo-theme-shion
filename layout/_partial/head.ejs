<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title><%= page.title ? page.title + ' - ' + config.title : config.title %></title>

<% if (page.excerpt) { %>
<meta name="description" content="<%= strip_html(page.excerpt).trim().substring(0, 160) %>">
<% } else if (config.description) { %>
<meta name="description" content="<%= config.description %>">
<% } %>

<meta property="og:title" content="<%= page.title || config.title %>">
<meta property="og:type" content="<%= page.layout === 'post' ? 'article' : 'website' %>">
<meta property="og:url" content="<%= config.url.replace(/\/$/, '') + '/' + page.path %>">
<meta property="og:site_name" content="<%= config.title %>">
<% if (page.excerpt) { %>
<meta property="og:description" content="<%= strip_html(page.excerpt).trim().substring(0, 200) %>">
<% } %>
<% if (page.og_image) { %>
<meta property="og:image" content="<%= page.og_image %>">
<% } %>

<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= page.title || config.title %>">
<% if (page.excerpt) { %>
<meta name="twitter:description" content="<%= strip_html(page.excerpt).trim().substring(0, 200) %>">
<% } %>

<link rel="canonical" href="<%= config.url.replace(/\/$/, '') + '/' + page.path %>">
<% if (config.feed && config.feed.atom) { %>
<link rel="alternate" href="<%= config.feed.atom %>" type="application/atom+xml" title="<%= config.title %>">
<% } %>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "<%= page.layout === 'post' ? 'Article' : 'WebSite' %>",
  "name": "<%= page.title || config.title %>",
  "url": "<%= config.url.replace(/\/$/, '') + '/' + page.path %>"<% if (page.layout === 'post') { %>,
  "datePublished": "<%= date(page.date, 'YYYY-MM-DDTHH:mm:ssZ') %>",
  "author": { "@type": "Person", "name": "<%= config.author || '' %>" }
  <% } %>
}
</script>

<meta name="theme-color" content="#6b7eb5">
<link rel="icon" href="<%= theme.favicon || '/images/shion/favicon.ico' %>">

<link rel="preconnect" href="https://cdn.jsdelivr.net">

<link rel="stylesheet" href="<%= url_for('/css/main.css') %>">

<% if (theme.custom_css) { %>
  <% if (theme.custom_css.startsWith('http') || theme.custom_css.startsWith('/')) { %>
  <link rel="stylesheet" href="<%= theme.custom_css.startsWith('http') ? theme.custom_css : url_for(theme.custom_css) %>">
  <% } else { %>
  <style><%- theme.custom_css %></style>
  <% } %>
<% } %>

<% if (theme.post && theme.post.image && theme.post.image.fancybox) { %>
<script src="https://cdn.jsdelivr.net/npm/medium-zoom@1/dist/medium-zoom.min.js"></script>
<% } %>

<%- partial('_partial/analytics') %>
<%- partial('_partial/math') %>

<script>
  (function() {
    var mode = '<%= theme.appearance.default_mode %>';
    var saved = localStorage.getItem('shion-theme');
    if (saved) { mode = saved; }
    else if (mode === 'auto') {
      mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    if (mode === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
    <% if (theme.appearance.font_size) { %>
    document.documentElement.style.setProperty('--font-size-root', '<%= theme.appearance.font_size %>');
    <% } %>
  })();
</script>

<% // No-JS fallback: show all content at full opacity if JS is disabled %>
<noscript>
  <style>
    .sidebar-inner,
    .content-card,
    .post,
    .page,
    .archive-item,
    .category-item,
    .pagination,
    .comments,
    .not-found,
    .widget,
    .tag-cloud-item,
    .post-card-wrapper,
    .post-content,
    .post-tags-footer,
    .post-share,
    .post-copyright,
    .post-nav {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>
