<div class="widget">
  <h4 class="widget-title"><%= __('archive_list') %></h4>
  <ul class="widget-list">
    <% var archives = []; %>
    <% site.posts.forEach(function(post) { %>
      <% var key = date(post.date, 'YYYY-MM'); %>
      <% if (!archives[key]) { archives[key] = 0; } %>
      <% archives[key]++; %>
    <% }) %>
    <% Object.keys(archives).sort().reverse().slice(0, 12).forEach(function(key) { %>
      <li class="widget-item">
        <a href="<%= url_for('/archives/' + key.replace('-', '/') + '/') %>"><%= key %></a>
        <span class="widget-count"><%= archives[key] %></span>
      </li>
    <% }) %>
  </ul>
</div>
