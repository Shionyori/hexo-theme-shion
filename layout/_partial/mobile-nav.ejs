<div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>

<nav class="mobile-nav" id="mobile-nav">
  <div class="mobile-nav-inner">
    <div class="mobile-nav-header">
      <span class="mobile-nav-title"><%= __('home') %></span>
      <button class="btn-icon mobile-nav-close" id="mobile-nav-close" aria-label="Close">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <ul class="mobile-nav-menu">
      <% for (var name in theme.menu) { %>
        <li>
          <a class="mobile-nav-link" href="<%= url_for(theme.menu[name]) %>"><%= __(name.toLowerCase()) || name %></a>
        </li>
      <% } %>
    </ul>

    <% if (theme.sidebar.enable && theme.sidebar.social) { %>
    <div class="mobile-nav-social">
      <% for (var name in theme.sidebar.social) { %>
        <a class="social-icon" href="<%= theme.sidebar.social[name] %>" target="_blank" rel="noopener" aria-label="<%= name %>">
          <span class="social-name"><%= name %></span>
        </a>
      <% } %>
    </div>
    <% } %>
  </div>
</nav>
