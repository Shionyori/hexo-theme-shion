<%
// ── Sidebar config — three-level fallback ──────────
//   page frontmatter  >  sidebar.layouts.<type>  >  global sidebar
//
// Determine page type via Hexo helpers (page.layout is empty for generated pages)
var type = is_post()   ? 'post'
         : is_home()   ? 'index'
         : is_archive()? 'archive'
         : is_category()? 'categories'
         : is_tag()    ? 'tags'
         : page.layout || 'page';

var P = page.sidebar || {};                                // page frontmatter override
var L = (((theme.sidebar || {}).layouts) || {})[type] || {}; // layout-level override
var G = theme.sidebar || {};                               // global defaults

var cfg = function(key, fallback) {                        // three-level resolver
  if (P[key] !== undefined) return P[key];
  if (L[key] !== undefined) return L[key];
  return fallback;
};

var show      = cfg('enable',   G.enable);
var hasProfile = cfg('profile', !G.profile || G.profile.enable !== false)
                 && ((G.avatar && G.avatar.enable) || config.author || config.description || G.social);
var hasMusic   = cfg('music',   !!(theme.music && theme.music.enable));
var widgets    = cfg('widgets', G.widgets || []);
var hasWidgets = widgets.length > 0;

if (!show) return;
if (type !== 'post' && !hasProfile && !hasMusic && !hasWidgets) return;
%>
<aside class="site-sidebar<%= type === 'post' ? ' sidebar-post' : '' %>" id="site-sidebar" data-position="<%= theme.sidebar.position || 'right' %>">

  <% if (type !== 'post') { %>
  <% // ── Non-post pages: profile card + sticky group ── %>

  <% if (hasProfile) { %>
  <section class="sidebar-card sidebar-profile">
    <% if (theme.sidebar.avatar.enable) { %>
    <div class="sidebar-avatar">
      <img src="<%= url_for(theme.sidebar.avatar.image) %>" alt="<%= config.author || config.title %>" width="96" height="96">
    </div>
    <% } %>
    <% if (config.author) { %>
    <div class="sidebar-author"><%= config.author %></div>
    <% } %>
    <% if (config.description) { %>
    <div class="sidebar-bio"><%= config.description %></div>
    <% } %>
    <% if (theme.sidebar.social) { %>
    <div class="sidebar-social">
      <% for (var name in theme.sidebar.social) { %>
        <a class="social-icon" href="<%= theme.sidebar.social[name] %>" target="_blank" rel="noopener" aria-label="<%= name %>" title="<%= name %>">
          <span class="social-name"><%= name %></span>
        </a>
      <% } %>
    </div>
    <% } %>
  </section>
  <% } %>

  <% if (hasMusic || hasWidgets) { %>
  <div class="sidebar-sticky-group">
    <% if (hasMusic) { %>
    <section class="sidebar-card sidebar-music">
      <%- partial('_partial/music-player') %>
    </section>
    <% } %>
    <% if (hasWidgets) { %>
    <% widgets.forEach(function(widget) { %>
    <section class="sidebar-card sidebar-widget">
      <%- partial('_partial/widgets/' + widget) %>
    </section>
    <% }) %>
    <% } %>
  </div>
  <% } %>

  <% } else { %>
  <% // ── Post pages: sticky group with music + TOC ── %>

  <div class="sidebar-sticky-group">
    <% if (hasMusic) { %>
    <section class="sidebar-card sidebar-music">
      <%- partial('_partial/music-player') %>
    </section>
    <% } %>

    <section class="sidebar-card sidebar-toc">
      <div class="sidebar-toc-header">
        <a class="sidebar-back-home" href="<%= url_for('/') %>" title="<%= __('home') %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </a>
        <span class="sidebar-toc-label"><%= page.title %></span>
      </div>
      <div class="sidebar-scroll">
      <%
      var headingsExist = /<h[1-6]/.test(page.content || '');
      var showToc = (page.toc !== false) && headingsExist;
      %>
      <% if (showToc) { %>
      <nav class="sidebar-toc">
        <%- toc(page.content, { max_depth: theme.post.toc_max_depth || 3, class: 'toc-list', list_number: false }) %>
      </nav>
      <% } else { %>
      <p class="toc-empty"><%= __('no_toc') %></p>
      <% } %>
      </div>
      <a class="sidebar-back-home-bottom" href="<%= url_for('/') %>">← <%= __('home') %></a>
    </section>
  </div>

  <% } %>
</aside>
