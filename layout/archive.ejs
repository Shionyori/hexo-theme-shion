<div class="archive content-card">
  <h1 class="archive-title"><%= __('archives') %></h1>

  <% var year = 0; %>
  <% page.posts.forEach(function(post) { %>
    <% var postYear = date(post.date, 'YYYY'); %>
    <% if (postYear !== year) { %>
      <% year = postYear; %>
      <h2 class="archive-year"><%= year %></h2>
    <% } %>

    <div class="archive-item">
      <time class="archive-date" datetime="<%= date(post.date, 'YYYY-MM-DD') %>">
        <%= date(post.date, 'MM-DD') %>
      </time>
      <a class="archive-post-title" href="<%= url_for(post.path) %>"><%= post.title %></a>
    </div>
  <% }) %>
</div>

<%- partial('_partial/pagination') %>
