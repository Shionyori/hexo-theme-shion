<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <%- partial('_partial/head') %>
  <script>
    window.__shionConfig = {
      katexCDN: '<%= theme.cdn && theme.cdn.katex ? theme.cdn.katex : "https://cdn.jsdelivr.net/npm/katex@0.16.9" %>',
      katexDelimiters: <%- JSON.stringify((theme.post && theme.post.math && theme.post.math.delimiters) || [
        { left: '$$', right: '$$', display: true },
        { left: '$', right: '$', display: false },
        { left: '\\[', right: '\\]', display: true },
        { left: '\\(', right: '\\)', display: false }
      ]) %>
    };
  </script>
</head>
<body>
  <%- partial('_partial/header') %>

  <%- partial('_partial/reading-progress') %>

<div id="pjax-container">
  <% // Full-width page-top background — outside container, edge-to-edge %>
  <%
    var coverEnabled = !theme.post || !theme.post.cover || theme.post.cover.enable !== false;
    var pageCover = coverEnabled ? (page.cover || (theme.post.cover && theme.post.cover.default)) : null;
    var hasCover = (pageCover && page.layout === 'post');
  %>
  <% if (hasCover) { %>
  <div class="page-bg">
  <% var coverUrl = (pageCover.startsWith('/') || pageCover.startsWith('http')) ? url_for(pageCover) : url_for(page.path + pageCover); %>
    <img src="<%= coverUrl %>" alt="">
  </div>
  <% } else if (theme.shion && theme.shion.background_image && page.type !== '404') { %>
  <div class="page-bg">
    <img src="<%= url_for(theme.shion.background_image) %>" alt="">
  </div>
  <% } %>

  <% // Hero area — above content, outside flex layout so sidebar sits below it %>
  <% if (page.type !== '404') { %>
  <% if (is_post()) { %>
  <section class="page-hero">
    <h1 class="hero-title"><%= page.title %></h1>
    <div class="hero-subtitle">
      <%- partial('_partial/post-meta', { post: page }) %>
    </div>
  </section>
  <% } else if (is_archive()) { %>
  <section class="page-hero">
    <h1 class="hero-title"><%= __('archives') %></h1>
  </section>
  <% } else if (is_category() || is_tag()) { %>
  <section class="page-hero">
    <h1 class="hero-title"><%= page.category || page.tag || '' %></h1>
  </section>
  <% } else if (is_home() && theme.shion.hero_enable) { %>
  <section class="page-hero">
    <h1 class="hero-title"><%= config.title %></h1>
    <% if (config.description) { %>
    <p class="hero-subtitle"><%= config.description %></p>
    <% } %>
  </section>
  <% } else { %>
  <section class="page-hero">
    <h1 class="hero-title"><%= page.title || '' %></h1>
  </section>
  <% } %>
  <% } %>

  <%
  // Sidebar enable: page frontmatter > layouts config > global
  var type = is_post()   ? 'post'
           : is_home()   ? 'index'
           : is_archive()? 'archive'
           : is_category()? 'categories'
           : is_tag()    ? 'tags'
           : page.layout || 'page';
  var P = page.sidebar || {};
  var L = (((theme.sidebar || {}).layouts) || {})[type] || {};
  var sidebarEnabled = P.enable !== undefined ? P.enable : (L.enable !== undefined ? L.enable : theme.sidebar.enable);
%>
<div class="container">
    <div class="content-wrapper">
      <% if (sidebarEnabled && theme.sidebar.position === 'left') { %>
      <%- partial('_partial/sidebar') %>
      <% } %>

      <main class="site-main">
        <%- body %>
      </main>

      <% if (sidebarEnabled && theme.sidebar.position !== 'left') { %>
      <%- partial('_partial/sidebar') %>
      <% } %>
    </div>
  </div>
</div>

  <%- partial('_partial/mobile-nav') %>
  <%- partial('_partial/footer') %>
  <%- partial('_partial/search') %>

  <%- partial('_partial/math') %>
  <script src="<%= url_for('/js/main.js') %>"></script>
</body>
</html>
