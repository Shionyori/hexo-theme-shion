{
  "name": "hexo-theme-shion",
  "version": "1.0.0",
  "description": "A Hexo blog theme themed around Shion Yorigami from Touhou Project",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build:scss": "sass src/scss/main.scss source/css/main.css --style compressed --quiet-deps",
    "build:ts": "tsc -p tsconfig.json",
    "build:client": "esbuild src/client/main.ts --bundle --minify --outfile=source/js/main.js",
    "build": "npm run build:ts && npm run build:client && npm run build:scss",
    "dev:scss": "sass --watch src/scss/main.scss source/css/main.css",
    "dev:ts": "tsc -p tsconfig.json --watch",
    "dev": "npm run build && concurrently \"npm:dev:scss\" \"npm:dev:ts\"",
    "clean": "rm -rf source/css/* source/js/* scripts/*"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "esbuild": "^0.20.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.0"
  }
}
