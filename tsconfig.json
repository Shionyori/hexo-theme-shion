{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "scripts",
    "rootDir": "src/ts",
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
